# ============================================================
# ReLoop Backend — Environment Configuration
# ============================================================
# Copy this to .env and fill in your values.
#
# APP_MODE controls behavior:
#   "demo"       → Persona login, mock payments, relaxed security
#   "production" → Cognito auth, real payments, strict security
# ============================================================

APP_MODE=demo
NODE_ENV=development
PORT=8080

# --- Database ---
MONGO_URI=mongodb://localhost:27017/reloop

# --- Auth (both modes) ---
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_EXPIRES_IN=7d

# --- Cognito (required when APP_MODE=production) ---
# Create a User Pool in AWS Console → Cognito
# Enable USER_PASSWORD_AUTH flow on the app client
COGNITO_REGION=ap-south-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=

# --- AI Grading ---
# Provider: anthropic | bedrock | nova | mock
# If no keys configured, falls back to "mock" automatically
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
NOVA_MODEL_ID=us.amazon.nova-lite-v1:0

# --- Storage ---
# "local" saves to ./uploads (demo/dev)
# "s3" saves to AWS S3 bucket (production)
STORAGE_DRIVER=local
S3_BUCKET=
S3_REGION=ap-south-1
PUBLIC_BASE_URL=http://localhost:8080

# --- Payment (Razorpay) ---
# Without keys, payment falls back to mock (simulated)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Security ---
CORS_ORIGINS=http://localhost:3000
WEBHOOK_SECRET=change-me-to-a-random-hex-string
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Logging ---
LOG_LEVEL=info


